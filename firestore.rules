rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is accessing their own data
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Match any document in the 'users' collection
    match /users/{userId} {
      // Allow a user to read and write their own document
      allow read, write: if isAuthenticated() && isOwner(userId);

      // Match roadmaps subcollection
      match /roadmaps/{roadmapId} {
        allow read: if (isAuthenticated() && isOwner(userId)) || resource.data.is_public == true;
        allow write: if isAuthenticated() && isOwner(userId);

        // Match progress subcollection
        match /progress/{lessonId} {
          allow read, write: if isAuthenticated() && isOwner(userId);
        }
      }
    }

    // Match public roadmaps collection
    match /public_roadmaps/{roadmapId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == request.resource.data.user_id;
      allow delete: if request.auth != null && request.auth.uid == resource.data.user_id;
    }
  }
}
