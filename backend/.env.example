# RoadmapAI Backend Environment Variables — EXAMPLE
# Copy this file to .env and fill in real values. Never commit .env to git.

# Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin Credentials (optional if running locally with gcloud auth login or on GCP)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
